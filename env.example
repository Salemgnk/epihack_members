# ================================
# SUPABASE CONFIGURATION
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ================================
# ADMIN CONFIGURATION
# ================================
# Super-admin principal (can promote/demote other admins)
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=admin@example.com

# Service role key for admin operations (server-side only)
# WARNING: Never expose this key to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ================================
# SITE CONFIGURATION
# ================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ================================
# HACKTHEBOX API (Optional)
# ================================
# Token API HackTheBox for automatic sync
# Get it from: https://www.hackthebox.com/home/settings
HTB_API_TOKEN=your_htb_token_here

# ================================
# DISCORD BOT (Optional)
# ================================
# Discord bot token for activity sync
DISCORD_BOT_TOKEN=your_discord_token_here

# ================================  
# GITHUB API (Optional)
# ================================
# GitHub Personal Access Token for contributions tracking
GITHUB_TOKEN=ghp_your_github_token_here
